{
  "compilerOptions": {
    "composite": true,
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": ["ES2017", "DOM"],
    "types": ["@figma/plugin-typings"],
    "noEmit": true
  },
  "include": ["src/code/**/*.ts", "src/shared/**/*.ts"]
}
