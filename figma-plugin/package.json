{
  "name": "drama-style-ds-to-markdown",
  "version": "0.0.1",
  "private": true,
  "description": "Figma plugin that extracts design-system spec as LLM-ready Markdown",
  "scripts": {
    "build:code": "esbuild src/code/index.ts --bundle --outfile=dist/code.js --target=es2017 --format=iife --log-level=info",
    "build:ui": "vite build",
    "build": "npm run build:code && npm run build:ui",
    "watch:code": "esbuild src/code/index.ts --bundle --outfile=dist/code.js --target=es2017 --format=iife --watch",
    "watch:ui": "vite build --watch",
    "dev": "concurrently -n code,ui -c blue,magenta \"npm:watch:code\" \"npm:watch:ui\"",
    "typecheck": "tsc -p tsconfig.code.json --noEmit && tsc -p tsconfig.ui.json --noEmit"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.100.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.0.3"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
